async function handleImport(e){
  const f=e.target.files[0]; if(!f) return;
  const r=new FileReader();
  r.onload=async ev=>{
    try{
      const d=JSON.parse(ev.target.result);
      if(d.docs&&d.events&&d.alerts&&d.pending&&d.fallos){
        if(!confirm('¿Reemplazar todos los datos actuales con los del archivo importado?')) return;
        db=d; if(!db.procesos) db.procesos=[];
        await save(); alert('✓ Datos importados y cifrados correctamente.');
      } else { alert('Archivo inválido'); }
    }catch(err){ alert('Error al importar: '+err.message); }
  };
  r.readAsText(f); e.target.value='';
}

