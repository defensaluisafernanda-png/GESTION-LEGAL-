function fmt(s){ if(!s) return '—'; const[y,m,d]=s.split('-'); return `${d}/${m}/${y}`; }
function daysLeft(s){ if(!s) return null; const t=new Date(); t.setHours(0,0,0,0); return Math.ceil((new Date(s+'T00:00:00')-t)/86400000); }
function deadlineBadge(s){
  if(!s) return '';
  const d=daysLeft(s);
  if(d<0) return `<span class="badge danger">Vencido ${Math.abs(d)}d</span>`;
  if(d===0) return `<span class="badge danger">🔴 HOY</span>`;
  if(d<=5) return `<span class="badge danger">⚠️ ${d}d</span>`;
  if(d<=15) return `<span class="badge warning">${d} días</span>`;
  return `<span class="badge neutral">${fmt(s)}</span>`;
}

