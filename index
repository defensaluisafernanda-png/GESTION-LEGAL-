  const btn = document.querySelector('.lock-btn');
  btn.disabled = true; btn.textContent = 'Cifrando datos...';
  try{
    const salt = await getSalt();
    const hash = await hashPwd(p1, salt);
    localStorage.setItem(HASH_KEY, hash);
    cryptoKey = await deriveKey(p1, salt);
    seedData();
    await saveEncrypted();
    enterApp();
  }catch(e){ showErr('Error: '+e.message); btn.disabled=false; btn.textContent='✓ Crear contraseña y entrar'; }
