// ===== INACTIVITY =====
function startTimeout(){
  const ms = TIMEOUT_MIN * 60 * 1000;
  clearTimeout(timeoutTimer);
  timeoutStart = Date.now();
  const bar = document.getElementById('timeoutBar');
  bar.style.display='block';
  bar.classList.remove('warning');
  bar.style.transform='scaleX(1)';
  timeoutTimer = setTimeout(showInactivityOverlay, ms);
  updateTimeoutUI();
}

function updateTimeoutUI(){
  const remaining = Math.max(0, TIMEOUT_MIN*60*1000 - (Date.now()-timeoutStart));
  const mins = Math.floor(remaining/60000);
  const secs = Math.floor((remaining%60000)/1000);
  const frac = remaining / (TIMEOUT_MIN*60*1000);
  const bar = document.getElementById('timeoutBar');
  bar.style.transform=`scaleX(${frac})`;
  if(frac < 0.2) bar.classList.add('warning'); else bar.classList.remove('warning');
  const ti = document.getElementById('timeoutInfo');
  if(ti) ti.textContent = `Bloqueo en ${mins}:${secs.toString().padStart(2,'0')}`;
  if(remaining > 0) setTimeout(updateTimeoutUI, 1000);
}

function resetTimeout(){
  if(cryptoKey) startTimeout();
}

function showInactivityOverlay(){
  document.getElementById('inactivityOverlay').classList.add('show');
  document.getElementById('inactPwd').value='';
  document.getElementById('inactError').style.display='none';
  setTimeout(()=>document.getElementById('inactPwd').focus(),100);
}

