// ===== STRENGTH =====
function getStrengthScore(p){
  let s=0;
  if(p.length>=8) s++;
  if(p.length>=12) s++;
  if(/[A-Z]/.test(p)) s++;
  if(/[0-9]/.test(p)) s++;
  if(/[^A-Za-z0-9]/.test(p)) s++;
  return s;
}

function checkStrength(p, barId, labelId){
  const s = getStrengthScore(p);
  const bar = document.getElementById(barId);
  const label = document.getElementById(labelId);
  const colors=['#e05050','#e09040','#e09040','#40b070','#1a7a4a'];
  const labels=['Muy débil','Débil','Regular','Fuerte','Muy fuerte'];
  const pcts=['20%','40%','60%','80%','100%'];
  bar.style.width = p ? pcts[Math.min(s,4)] : '0';
  bar.style.background = p ? colors[Math.min(s,4)] : '';
  label.textContent = p ? labels[Math.min(s,4)] : '';
  label.style.color = p ? colors[Math.min(s,4)] : '';
}

