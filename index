function calcDeadline(){
  const pl=document.getElementById('d_plazo').value, fr=document.getElementById('d_fechaRad').value;
  if(!pl||!fr) return;
  let d=new Date(fr+'T00:00:00'), added=0;
  while(added<parseInt(pl)){ d.setDate(d.getDate()+1); const wd=d.getDay(); if(wd!==0&&wd!==6) added++; }
  document.getElementById('d_vence').value=d.toISOString().split('T')[0];
}

